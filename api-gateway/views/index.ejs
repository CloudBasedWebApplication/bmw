<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f3f5f7;
        --panel: #ffffff;
        --text: #111111;
        --muted: #5c6670;
        --accent: #0066b1;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(0, 102, 177, 0.12), transparent 30%),
          linear-gradient(180deg, #fafbfc 0%, var(--bg) 100%);
        color: var(--text);
      }

      main {
        width: min(720px, calc(100% - 32px));
        padding: 40px;
        border-radius: 24px;
        background: var(--panel);
        box-shadow: 0 18px 48px rgba(17, 17, 17, 0.08);
      }

      h1 {
        margin: 0 0 12px;
        font-size: clamp(2rem, 5vw, 3.5rem);
        line-height: 1;
      }

      p {
        margin: 0;
        font-size: 1.05rem;
        line-height: 1.6;
        color: var(--muted);
      }

      strong {
        color: var(--accent);
      }

      .video-wrapper {
        width: 100%;
        margin-bottom: 32px;
        border-radius: 16px;
        overflow: hidden;
      }

      .video-wrapper video {
        width: 100%;
        display: block;
      }
    </style>
  </head>
  <body>
    <main>
      <div class="video-wrapper">
        <video autoplay muted loop playsinline>
          <source src="https://www.bmw.com/content/dam/bmw/marketBMWCOM/bmw_com/home/sky-04-media-hd-recut-v2b.mp4" type="video/mp4" />
        </video>
      </div>
      <h1><%= headline %></h1>
      <p>
        <strong>index.html</strong> zeigt auf diese EJS-Ansicht.
        <%= message %>
      </p>
    </main>
  </body>
</html>
