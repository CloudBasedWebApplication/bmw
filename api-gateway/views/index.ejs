<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      :root {
        --bg: #f5f7f9;
        --text: #060606;
        --muted: #636366;
        --panel: rgba(255, 255, 255, 0.75);
        --line: rgba(0, 0, 0, 0.06);
        --accent: #0066b1; /* BMW Blue */
        --accent-dark: #003e70;
        --card-shadow: 0 12px 40px rgba(0, 0, 0, 0.04);
        --radius: 20px;
      }

      * {
        box-sizing: border-box;
        -webkit-font-smoothing: antialiased;
      }

      body {
        margin: 0;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background-color: var(--bg);
        background-image: 
          radial-gradient(at 0% 0%, rgba(0, 102, 177, 0.05) 0px, transparent 50%),
          radial-gradient(at 100% 100%, rgba(0, 102, 177, 0.03) 0px, transparent 50%);
        color: var(--text);
        line-height: 1.5;
      }

      /* Topbar Refinement */
      .topbar {
        position: sticky;
        top: 0;
        z-index: 100;
        padding: 20px;
      }

      .topbar-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 12px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--panel);
        backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 999px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
      }

      .brand {
        text-decoration: none;
        color: var(--text);
        font-weight: 800;
        font-size: 1.1rem;
        letter-spacing: -0.02em;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .nav-links {
        display: flex;
        gap: 4px;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--muted);
        padding: 8px 16px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
      }

      .nav-links a:hover {
        color: var(--text);
        background: rgba(0,0,0,0.04);
      }

      .nav-links a.active {
        background: var(--text);
        color: white;
      }

      main {
        max-width: 1280px;
        margin: 0 auto;
        padding: 20px;
      }

      /* Hero Section */
      .hero {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
      }

      .panel {
        background: var(--panel);
        backdrop-filter: blur(20px);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        overflow: hidden;
        transition: border-color 0.3s ease;
      }

      .hero-copy {
        padding: 48px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .eyebrow {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
        margin-bottom: 16px;
      }

      h1 {
        margin: 0 0 20px;
        font-size: clamp(2.5rem, 5vw, 4rem);
        line-height: 1.1;
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .hero-copy p {
        margin: 0 0 40px;
        font-size: 1.15rem;
        color: var(--muted);
        max-width: 50ch;
      }

      /* Stats/Infra Grid */
      .infra-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
      }

      .infra-card {
        padding: 20px;
        background: rgba(255,255,255,0.4);
        border: 1px solid rgba(0,0,0,0.03);
        border-radius: 16px;
      }

      .infra-card span {
        display: block;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: 4px;
      }

      .infra-card strong {
        font-size: 1rem;
        color: var(--text);
      }

      /* Video Panel */
      .video-panel {
        position: relative;
        min-height: 450px;
      }

      .video-panel video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
      }

      .video-panel:hover video {
        transform: scale(1.05);
      }

      .video-overlay {
        position: absolute;
        bottom: 24px;
        left: 24px;
        right: 24px;
        padding: 24px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px) brightness(0.8);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 16px;
        color: white;
      }

      /* Services Grid */
      .services {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
      }

      .service-card {
        padding: 32px;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .service-card:hover {
        transform: translateY(-8px);
        border-color: var(--accent);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
      }

      .service-path {
        font-family: monospace;
        font-size: 0.8rem;
        color: var(--accent);
        margin-bottom: 20px;
        opacity: 0.7;
      }

      .service-card h2 {
        margin: 0 0 12px;
        font-size: 1.5rem;
        letter-spacing: -0.01em;
      }

      .service-card p {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.6;
      }

      /* Accent Variations */
      .service-card.dark {
        background: #060606;
        color: white;
      }
      .service-card.dark p { color: #86868b; }

      @media (max-width: 1024px) {
        .hero { grid-template-columns: 1fr; }
        .hero-copy { padding: 32px; }
      }

      @media (max-width: 768px) {
        .nav-links { display: none; } /* Mobile menu could be added here */
        .infra-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          BMW Gateway
        </a>
        <nav class="nav-links">
          <a href="/" class="active">Home</a>
          <a href="/car-configurator">Configurator</a>
          <a href="/merch-shop">Shop</a>
          <a href="/ai-feature">AI</a>
          <a href="/road-to-supercar">Road To Supercar</a>
          <a href="/shopping-cart">Cart</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="panel hero-copy">
          <div class="eyebrow">Enterprise Hub</div>
          <h1><%= headline %></h1>
          <p><%= message %></p>

          <div class="infra-grid">
            <% infrastructure.forEach(function(item) { %>
              <div class="infra-card">
                <span><%= item.label %></span>
                <strong><%= item.value %></strong>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="panel video-panel">
          <video autoplay muted loop playsinline>
            <source src="https://www.bmw.com/content/dam/bmw/marketBMWCOM/bmw_com/home/sky-04-media-hd-recut-v2b.mp4" type="video/mp4" />
          </video>
          <div class="video-overlay">
            <h3 style="margin:0 0 8px 0; font-size: 1rem;">Service Hub</h3>
            <p style="margin:0; font-size: 0.85rem; opacity: 0.9;">Zentraler Einstiegspunkt für Konfiguration, Merch und KI-Features.</p>
          </div>
        </div>
      </section>

      <section class="services">
        <% services.forEach(function(service) { %>
          <a class="panel service-card <%= service.accent %>" href="<%= service.path %>">
            <span class="service-path"><%= service.path %></span>
            <h2><%= service.name %></h2>
            <p><%= service.description %></p>
          </a>
        <% }) %>
      </section>
    </main>
  </body>
</html>