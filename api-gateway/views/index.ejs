<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      :root {
        color-scheme: light;
        --bg: #eef2f6;
        --text: #111111;
        --muted: #5f6873;
        --panel: rgba(255, 255, 255, 0.86);
        --line: rgba(17, 17, 17, 0.08);
        --accent: #0059a8;
        --accent-strong: #0d1b2a;
        --card-shadow: 0 24px 60px rgba(17, 17, 17, 0.10);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(0, 89, 168, 0.18), transparent 26%),
          radial-gradient(circle at top right, rgba(13, 27, 42, 0.08), transparent 30%),
          linear-gradient(180deg, #fafbfc 0%, var(--bg) 100%);
        color: var(--text);
      }

      main {
        width: min(1180px, calc(100% - 32px));
        margin: 32px auto;
        padding: 24px;
      }

      .hero {
        display: grid;
        grid-template-columns: 1.35fr 0.95fr;
        gap: 24px;
        margin-bottom: 24px;
      }

      .panel {
        background: var(--panel);
        backdrop-filter: blur(16px);
        border: 1px solid var(--line);
        border-radius: 28px;
        box-shadow: var(--card-shadow);
      }

      .hero-copy {
        padding: 28px;
      }

      .eyebrow {
        display: inline-flex;
        margin-bottom: 18px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(0, 89, 168, 0.10);
        color: var(--accent);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0 0 16px;
        font-size: clamp(2.3rem, 6vw, 4.8rem);
        line-height: 0.95;
        letter-spacing: -0.04em;
      }

      .hero-copy p {
        margin: 0 0 28px;
        max-width: 58ch;
        font-size: 1.05rem;
        line-height: 1.7;
        color: var(--muted);
      }

      .infra-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      .infra-card {
        padding: 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid var(--line);
      }

      .infra-card span {
        display: block;
        margin-bottom: 6px;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .infra-card strong {
        display: block;
        font-size: 0.98rem;
        line-height: 1.5;
        color: var(--accent-strong);
        word-break: break-word;
      }

      .video-panel {
        position: relative;
        overflow: hidden;
        min-height: 360px;
      }

      .video-panel video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .video-overlay {
        position: absolute;
        inset: auto 20px 20px 20px;
        padding: 18px 20px;
        border-radius: 20px;
        background: rgba(13, 27, 42, 0.74);
        color: #f7f9fb;
      }

      .video-overlay strong {
        display: block;
        margin-bottom: 8px;
        font-size: 0.95rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .video-overlay p {
        margin: 0;
        line-height: 1.55;
        color: rgba(247, 249, 251, 0.82);
      }

      .services {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 18px;
      }

      .service-card {
        display: block;
        padding: 22px;
        text-decoration: none;
        color: inherit;
        transform: translateY(0);
        transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
      }

      .service-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 28px 68px rgba(17, 17, 17, 0.14);
        border-color: rgba(0, 89, 168, 0.24);
      }

      .service-card.primary {
        background: linear-gradient(180deg, rgba(0, 89, 168, 0.08) 0%, rgba(255, 255, 255, 0.92) 100%);
      }

      .service-card.dark {
        background: linear-gradient(180deg, rgba(13, 27, 42, 0.92) 0%, rgba(28, 42, 59, 0.88) 100%);
        color: #f5f7fa;
      }

      .service-card.dark p,
      .service-card.dark .service-path {
        color: rgba(245, 247, 250, 0.78);
      }

      .service-card.light {
        background: rgba(255, 255, 255, 0.9);
      }

      .service-path {
        display: inline-block;
        margin-bottom: 16px;
        font-size: 0.84rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        color: var(--accent);
      }

      .service-card h2 {
        margin: 0 0 10px;
        font-size: 1.35rem;
      }

      .service-card p {
        margin: 0;
        line-height: 1.65;
        color: var(--muted);
      }

      @media (max-width: 900px) {
        .hero {
          grid-template-columns: 1fr;
        }

        .infra-grid {
          grid-template-columns: 1fr;
        }

        .video-panel {
          min-height: 280px;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <div class="panel hero-copy">
          <div class="eyebrow">Gateway</div>
          <h1><%= headline %></h1>
          <p><%= message %></p>

          <div class="infra-grid">
            <% infrastructure.forEach(function(item) { %>
              <div class="infra-card">
                <span><%= item.label %></span>
                <strong><%= item.value %></strong>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="panel video-panel">
          <video autoplay muted loop playsinline>
            <source src="https://www.bmw.com/content/dam/bmw/marketBMWCOM/bmw_com/home/sky-04-media-hd-recut-v2b.mp4" type="video/mp4" />
          </video>
          <div class="video-overlay">
            <strong>Service Hub</strong>
            <p>Ein Einstiegspunkt fuer Configurator, Merch Shop, AI Feature, Shopping Cart und weitere Views.</p>
          </div>
        </div>
      </section>

      <section class="services">
        <% services.forEach(function(service) { %>
          <a class="panel service-card <%= service.accent %>" href="<%= service.path %>">
            <span class="service-path"><%= service.path %></span>
            <h2><%= service.name %></h2>
            <p><%= service.description %></p>
          </a>
        <% }) %>
      </section>
    </main>
  </body>
</html>
