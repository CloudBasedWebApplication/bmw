# Application
APP_ENV=development

# Database
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=bmw_app
MYSQL_USER=bmw_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# Cache
REDIS_HOST=redis
REDIS_PORT=6379

# Object Storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=change_me
MINIO_BUCKET=configurator-images
# Public browser URL for MinIO object links.
# Local default: http://localhost:9000
# LAN example: http://192.168.178.20:9000
# GitHub Codespaces example: https://<codespace-name>-9000.app.github.dev
MINIO_PUBLIC_URL=http://localhost:9000

# External APIs
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GOOGLE_MAPS_API_KEY=replace_me
