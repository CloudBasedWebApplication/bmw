<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Road to Supercar | BMW Journey</title>
    <style>
      :root {
        --accent: #0066b1;
        --accent-dark: #004a80;
        --bg: #f5f7f9;
        --panel: #ffffff;
        --text: #0f172a;
        --muted: #64748b;
        --radius: 20px;
        --shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
      }

      * { box-sizing: border-box; -webkit-font-smoothing: antialiased; }

      body {
        margin: 0;
        font-family: 'Inter', -apple-system, system-ui, sans-serif;
        background-color: var(--bg);
        color: var(--text);
        line-height: 1.5;
      }

      /* Navbar */
      .topbar { padding: 20px; }
      .topbar-inner {
        max-width: 1100px; margin: 0 auto; padding: 12px 24px;
        background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(15px);
        border-radius: 999px; border: 1px solid rgba(255,255,255,0.4);
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        display: flex; align-items: center; justify-content: space-between;
      }
      .brand { text-decoration: none; color: var(--text); font-weight: 800; font-size: 1.1rem; }
      .nav-links { display: flex; gap: 4px; }
      .nav-links a {
        text-decoration: none; color: var(--muted); padding: 8px 16px;
        border-radius: 999px; font-size: 0.85rem; font-weight: 500; transition: 0.2s;
      }
      .nav-links a.active, .nav-links a:hover { background: var(--text); color: white; }

      .layout { max-width: 1100px; margin: 0 auto; padding: 20px 20px 40px; }

      header.page-header { margin-bottom: 32px; }
      h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; margin: 0 0 8px; }
      .subtitle { color: var(--muted); font-size: 1.1rem; }

      /* Control Dashboard */
      .controls {
        display: flex; gap: 12px; margin-bottom: 24px;
        background: var(--panel); padding: 12px;
        border-radius: 16px; box-shadow: var(--shadow);
        border: 1px solid rgba(0,0,0,0.05);
        align-items: center;
      }

      select {
        flex: 1; padding: 12px 16px; border: 1px solid #e2e8f0;
        border-radius: 12px; font-size: 1rem; font-family: inherit;
        background: #f8fafc; color: var(--text); cursor: pointer; outline: none;
      }
      select:focus { border-color: var(--accent); background: #fff; }

      .route-btn {
        padding: 14px 28px; border: none; border-radius: 12px;
        background: var(--accent); color: #fff; font-size: 1rem;
        font-weight: 700; cursor: pointer; transition: 0.3s;
      }
      .route-btn:hover { background: var(--accent-dark); transform: translateY(-1px); }

      /* Map Container */
      #map {
        width: 100%; height: 600px; border-radius: 24px;
        box-shadow: var(--shadow); background: #e8ecef;
        border: 4px solid #fff;
      }

      /* Route Info Badge */
      .info-badge {
        display: inline-flex; align-items: center; gap: 8px;
        margin-top: 16px; padding: 10px 20px;
        background: var(--text); color: white;
        border-radius: 999px; font-size: 0.9rem; font-weight: 600;
        opacity: 0; transform: translateY(10px); transition: 0.4s;
      }
      .info-badge.visible { opacity: 1; transform: translateY(0); }

      /* No Key State */
      .no-key {
        text-align: center; padding: 100px 40px; color: var(--muted);
        background: var(--panel); border-radius: 32px; box-shadow: var(--shadow);
      }
      .no-key code { background: #f1f5f9; padding: 4px 8px; border-radius: 6px; color: var(--accent); }

      @media (max-width: 640px) {
        .controls { flex-direction: column; align-items: stretch; }
        #map { height: 400px; }
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">BMW Gateway</a>
        <nav class="nav-links">
          <a href="/">Home</a>
          <a href="/car-configurator">Configurator</a>
          <a href="/merch-shop">Shop</a>
          <a href="/ai-feature">AI</a>
          <a href="/road-to-supercar" class="active">Road To Supercar</a>
          <a href="/shopping-cart">Warenkorb</a>
        </nav>
      </div>
    </header>

    <div class="layout">
      <header class="page-header">
        <h1>Road to Supercar</h1>
        <p class="subtitle">Planen Sie Ihre Route zu den exklusivsten BMW Standorten.</p>
      </header>

      <% if (mapsApiKey) { %>
        <div class="controls">
          <select id="destination">
            <option value="" disabled selected>Zielort wählen...</option>
          </select>
          <button class="route-btn" id="routeBtn">Route berechnen</button>
        </div>

        <div id="map"></div>
        
        <div class="info-badge" id="routeInfo"></div>

        <script>
          fetch("/api/destinations")
            .then(r => r.json())
            .then(destinations => {
              const sel = document.getElementById("destination");
              destinations.forEach(d => {
                const opt = document.createElement("option");
                opt.value = d.value;
                opt.textContent = d.label;
                sel.appendChild(opt);
              });
            });

          let map, directionsService, directionsRenderer;

          function initMap() {
            // Stylishe Map-Optionen (Silver-Look)
            map = new google.maps.Map(document.getElementById("map"), {
              zoom: 6,
              center: { lat: 51.1657, lng: 10.4515 },
              disableDefaultUI: false,
              styles: [
                { "featureType": "water", "elementType": "geometry", "stylers": [{ "color": "#e9e9e9" }, { "lightness": 17 }] },
                { "featureType": "landscape", "elementType": "geometry", "stylers": [{ "color": "#f5f5f5" }, { "lightness": 20 }] }
              ]
            });
            directionsService  = new google.maps.DirectionsService();
            directionsRenderer = new google.maps.DirectionsRenderer();
            directionsRenderer.setMap(map);
          }

          document.getElementById("routeBtn").addEventListener("click", () => {
            const dest = document.getElementById("destination").value;
            const info = document.getElementById("routeInfo");
            if (!dest) return;

            info.textContent = "Standort wird ermittelt...";
            info.classList.add("visible");

            if (!navigator.geolocation) {
              info.textContent = "Geolocation nicht unterstützt.";
              return;
            }

            navigator.geolocation.getCurrentPosition(pos => {
              const origin = { lat: pos.coords.latitude, lng: pos.coords.longitude };
              directionsService.route({
                origin,
                destination: dest,
                travelMode: google.maps.TravelMode.DRIVING,
              }, (result, status) => {
                if (status === "OK") {
                  directionsRenderer.setDirections(result);
                  const leg = result.routes[0].legs[0];
                  info.innerHTML = `<span>📍 ${leg.distance.text}</span> <span style="margin-left:12px">⏱️ ${leg.duration.text}</span>`;
                } else {
                  info.textContent = "Fehler: " + status;
                }
              });
            }, () => {
              info.textContent = "Standortzugriff verweigert.";
            });
          });
        </script>
        <script src="https://maps.googleapis.com/maps/api/js?key=<%= mapsApiKey %>&callback=initMap" async defer></script>
      <% } else { %>
        <div class="no-key">
          <div style="font-size: 3rem; margin-bottom: 20px;">🗺️</div>
          <h2 style="margin: 0 0 10px;">API-Key erforderlich</h2>
          <p>Bitte konfigurieren Sie den <code>GOOGLE_MAPS_API_KEY</code> in Ihrer Umgebung.</p>
        </div>
      <% } %>
    </div>
  </body>
</html>
