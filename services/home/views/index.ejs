<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bayerische Motoren Werke AG | Home</title>
    <style>
      @font-face {
        font-family: 'BMWTypeNext';
        font-style: normal;
        font-weight: 200;
        font-display: swap;
        src: url('/home/static/fonts/BMWTypeNextLatin-Thin.woff2') format('woff2'),
             url('/home/static/fonts/BMWTypeNextLatin-Thin.woff') format('woff');
      }
      @font-face {
        font-family: 'BMWTypeNext';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/home/static/fonts/BMWTypeNextLatin-Light.woff2') format('woff2'),
             url('/home/static/fonts/BMWTypeNextLatin-Light.woff') format('woff');
      }
      @font-face {
        font-family: 'BMWTypeNext';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url('/home/static/fonts/BMWTypeNextLatin-Bold.woff2') format('woff2'),
             url('/home/static/fonts/BMWTypeNextLatin-Bold.woff') format('woff');
      }

      :root {
        --accent: #1c69d4;
        --accent-dark: #114a96;
        --ink: #111827;
        --ink-soft: #394150;
        --muted: #697386;
        --line: rgba(17, 24, 39, 0.12);
        --paper: #f6f7f9;
        --panel: #ffffff;
        --dark: #0b0f14;
        --dark-2: #151b24;
        --radius: 8px;
        --shadow: 0 20px 55px rgba(16, 24, 40, 0.12);
      }

      * {
        box-sizing: border-box;
        -webkit-font-smoothing: antialiased;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: 'BMWTypeNext', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--paper);
        color: var(--ink);
        line-height: 1.5;
      }

      a {
        color: inherit;
      }

      img,
      video {
        max-width: 100%;
      }

      .page-shell {
        width: min(1180px, calc(100% - 40px));
        margin: 0 auto;
      }

      .site-nav {
        position: absolute;
        top: 24px;
        left: 50%;
        z-index: 5;
        width: min(1180px, calc(100% - 40px));
        min-height: 64px;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 12px 14px 12px 20px;
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: var(--radius);
        background: rgba(7, 12, 18, 0.38);
        backdrop-filter: blur(18px);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.25);
      }

      .brand {
        display: inline-flex;
        flex-direction: column;
        gap: 2px;
        text-decoration: none;
        min-width: 230px;
      }

      .brand strong {
        font-size: clamp(0.9rem, 1.5vw, 1.06rem);
        line-height: 1.1;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      .brand span {
        color: rgba(255, 255, 255, 0.72);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
        flex-wrap: wrap;
      }

      .nav-links a {
        min-height: 40px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: var(--radius);
        color: rgba(255, 255, 255, 0.78);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: color 0.2s ease, background 0.2s ease;
      }

      .nav-links a:hover,
      .nav-links a.active {
        color: #fff;
        background: rgba(255, 255, 255, 0.12);
      }

      .hero {
        position: relative;
        min-height: 100vh;
        width: 100%;
        overflow: hidden;
        color: #fff;
        background: #000;
      }

      .hero-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(180deg, rgba(0, 0, 0, 0.22) 0%, rgba(0, 0, 0, 0.18) 45%, rgba(0, 0, 0, 0.62) 100%),
          linear-gradient(90deg, rgba(0, 0, 0, 0.38), rgba(0, 0, 0, 0.05) 55%, rgba(0, 0, 0, 0.3));
      }

      .hero-overlay {
        position: relative;
        z-index: 2;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 130px 24px 88px;
      }

      .hero-title {
        margin: 0;
        font-size: clamp(2.7rem, 7vw, 6.4rem);
        font-weight: 700;
        letter-spacing: 0;
        line-height: 1.02;
        text-shadow: 0 8px 30px rgba(0, 0, 0, 0.45);
      }

      .hero-subtitle {
        margin: 18px 0 0;
        color: rgba(255, 255, 255, 0.86);
        font-size: clamp(1rem, 1.5vw, 1.25rem);
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .hero-cta {
        margin-top: 34px;
        min-height: 52px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 30px;
        border-radius: var(--radius);
        background: #fff;
        color: var(--ink);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        box-shadow: 0 14px 35px rgba(0, 0, 0, 0.28);
        transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
      }

      .hero-cta:hover {
        background: var(--accent);
        color: #fff;
        transform: translateY(-2px);
      }

      .scroll-hint {
        position: absolute;
        bottom: 34px;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(255, 255, 255, 0.76);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      .experience-section {
        background:
          linear-gradient(rgba(17, 24, 39, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(17, 24, 39, 0.045) 1px, transparent 1px),
          var(--paper);
        background-size: 44px 44px;
        padding: clamp(76px, 9vw, 124px) 0;
      }

      .section-kicker {
        margin: 0 0 12px;
        color: var(--accent);
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .section-title {
        margin: 0;
        max-width: 840px;
        color: var(--ink);
        font-size: clamp(2.05rem, 4vw, 4.15rem);
        font-weight: 700;
        letter-spacing: 0;
        line-height: 1.02;
      }

      .section-copy {
        margin: 18px 0 0;
        max-width: 670px;
        color: var(--muted);
        font-size: clamp(1rem, 1.55vw, 1.14rem);
      }

      .atelier-board {
        margin-top: 52px;
        display: grid;
        grid-template-columns: minmax(310px, 0.88fr) minmax(0, 1.12fr);
        min-height: 620px;
        border: 1px solid var(--line);
        background: #fff;
        box-shadow: var(--shadow);
      }

      .order-sheet {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: clamp(28px, 4.5vw, 54px);
        border-right: 1px solid var(--line);
      }

      .doc-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding-bottom: 22px;
        border-bottom: 1px solid var(--line);
      }

      .doc-meta span {
        display: inline-flex;
        min-height: 30px;
        align-items: center;
        padding: 0 10px;
        border: 1px solid rgba(17, 24, 39, 0.16);
        color: var(--ink-soft);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .order-sheet h3 {
        margin: 34px 0 0;
        max-width: 480px;
        font-size: clamp(2.2rem, 4vw, 4.45rem);
        font-weight: 700;
        letter-spacing: 0;
        line-height: 0.96;
      }

      .order-copy {
        margin: 22px 0 0;
        color: var(--ink-soft);
        font-size: 1.04rem;
      }

      .spec-table {
        margin: 38px 0 0;
        border-top: 1px solid var(--line);
      }

      .spec-row {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 18px;
        padding: 14px 0;
        border-bottom: 1px solid var(--line);
      }

      .spec-row span {
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .spec-row strong {
        color: var(--ink);
        font-size: 0.98rem;
        font-weight: 700;
      }

      .action-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 30px;
      }

      .button {
        min-height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 20px;
        border: 1px solid transparent;
        border-radius: 0;
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button.primary {
        background: var(--accent);
        color: #fff;
      }

      .button.primary:hover {
        background: var(--accent-dark);
      }

      .button.outline {
        border-color: rgba(17, 24, 39, 0.28);
        color: var(--ink);
        background: transparent;
      }

      .button.outline:hover {
        border-color: var(--ink);
        background: #fff;
      }

      .model-stage {
        position: relative;
        min-height: 620px;
        overflow: hidden;
        background: var(--dark);
        color: #fff;
      }

      .model-stage img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transform: scale(1.03);
      }

      .model-stage::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(180deg, rgba(9, 13, 18, 0.02), rgba(9, 13, 18, 0.82)),
          linear-gradient(90deg, rgba(9, 13, 18, 0.08), rgba(9, 13, 18, 0.44));
      }

      .stage-index {
        position: absolute;
        top: 28px;
        left: 28px;
        z-index: 1;
        color: rgba(255, 255, 255, 0.72);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .model-picks {
        position: absolute;
        top: 24px;
        right: 24px;
        z-index: 1;
        display: grid;
        gap: 8px;
      }

      .model-picks a {
        min-width: 116px;
        padding: 9px 11px;
        border: 1px solid rgba(255, 255, 255, 0.32);
        background: rgba(8, 12, 18, 0.42);
        color: #fff;
        text-decoration: none;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        backdrop-filter: blur(12px);
      }

      .model-picks a:hover {
        background: rgba(255, 255, 255, 0.16);
      }

      .stage-caption {
        position: absolute;
        left: clamp(24px, 4vw, 48px);
        right: clamp(24px, 4vw, 48px);
        bottom: clamp(24px, 4vw, 46px);
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 22px;
        align-items: end;
      }

      .stage-caption h4 {
        margin: 0;
        max-width: 560px;
        font-size: clamp(1.8rem, 3.3vw, 3.35rem);
        font-weight: 700;
        letter-spacing: 0;
        line-height: 1;
      }

      .stage-caption p {
        margin: 12px 0 0;
        max-width: 430px;
        color: rgba(255, 255, 255, 0.76);
      }

      .stage-coordinates {
        min-width: 150px;
        padding-left: 18px;
        border-left: 1px solid rgba(255, 255, 255, 0.28);
        color: rgba(255, 255, 255, 0.76);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .service-rail {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        margin-top: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.72);
      }

      .service-link {
        min-height: 154px;
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        grid-template-rows: auto 1fr;
        column-gap: 18px;
        row-gap: 10px;
        padding: 22px;
        border-right: 1px solid var(--line);
        color: var(--ink);
        text-decoration: none;
        transition: background 0.2s ease, transform 0.2s ease;
      }

      .service-link:last-child {
        border-right: 0;
      }

      .service-link:hover {
        background: #fff;
        transform: translateY(-2px);
      }

      .service-number {
        grid-row: 1 / span 2;
        color: var(--accent);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.12em;
      }

      .service-link h3 {
        margin: 0;
        font-size: 1.18rem;
        font-weight: 700;
        line-height: 1.18;
      }

      .service-link p {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .heritage-section {
        position: relative;
        overflow: hidden;
        min-height: 600px;
        background: #070b10;
        color: #fff;
      }

      .heritage-video {
        position: absolute;
        top: 0;
        right: 0;
        width: min(58%, 860px);
        height: 100%;
        object-fit: cover;
        opacity: 0.46;
      }

      .heritage-section::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(90deg, #070b10 0%, rgba(7, 11, 16, 0.94) 36%, rgba(7, 11, 16, 0.5) 68%, rgba(7, 11, 16, 0.8) 100%),
          linear-gradient(180deg, rgba(7, 11, 16, 0.1), rgba(7, 11, 16, 0.82));
      }

      .heritage-content {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 0.76fr) minmax(170px, 0.24fr);
        gap: 42px;
        align-items: end;
        padding: clamp(86px, 10vw, 132px) 0;
      }

      .heritage-content .section-kicker {
        color: #8fc0ff;
      }

      .heritage-title {
        margin: 0;
        max-width: 790px;
        font-size: clamp(2.2rem, 5vw, 5.15rem);
        font-weight: 700;
        letter-spacing: 0;
        line-height: 0.98;
      }

      .heritage-copy {
        max-width: 620px;
        margin: 24px 0 0;
        color: rgba(255, 255, 255, 0.74);
        font-size: 1.02rem;
      }

      .heritage-ledger {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        max-width: 860px;
        margin-top: 46px;
        border-top: 1px solid rgba(255, 255, 255, 0.24);
        border-bottom: 1px solid rgba(255, 255, 255, 0.24);
      }

      .ledger-item {
        padding: 22px 22px 22px 0;
        border-right: 1px solid rgba(255, 255, 255, 0.2);
      }

      .ledger-item + .ledger-item {
        padding-left: 22px;
      }

      .ledger-item:last-child {
        border-right: 0;
      }

      .ledger-item span {
        display: block;
        color: #8fc0ff;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .ledger-item strong {
        display: block;
        margin-top: 10px;
        font-size: 1.16rem;
        font-weight: 700;
        line-height: 1.18;
      }

      .heritage-mark {
        justify-self: end;
        padding-left: 28px;
        border-left: 1px solid rgba(255, 255, 255, 0.26);
        text-align: right;
      }

      .heritage-mark strong {
        display: block;
        font-size: clamp(3.8rem, 8vw, 8rem);
        font-weight: 200;
        line-height: 0.82;
      }

      .heritage-mark span {
        display: block;
        margin-top: 16px;
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .route-section {
        background: #fff;
        padding: clamp(78px, 9vw, 126px) 0;
      }

      .route-layout {
        margin-top: 42px;
        display: grid;
        grid-template-columns: minmax(290px, 0.42fr) minmax(0, 0.58fr);
        gap: 22px;
        align-items: start;
      }

      .route-panel {
        padding: 24px;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--paper);
      }

      .route-panel h3 {
        margin: 0 0 10px;
        font-size: 1.35rem;
        font-weight: 700;
        line-height: 1.15;
      }

      .route-panel p {
        margin: 0 0 22px;
        color: var(--muted);
      }

      .route-meta {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1px;
        margin-bottom: 22px;
        border: 1px solid var(--line);
        background: var(--line);
      }

      .route-meta div {
        display: grid;
        grid-template-columns: 92px 1fr;
        gap: 12px;
        padding: 11px 12px;
        background: #fff;
      }

      .route-meta span {
        color: var(--muted);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .route-meta strong {
        color: var(--ink);
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.25;
      }

      .controls {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
      }

      .route-field {
        display: flex;
        flex-direction: column;
        gap: 7px;
        min-width: 0;
      }

      .route-field label {
        font-size: 0.74rem;
        font-weight: 700;
        color: var(--muted);
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .route-input {
        width: 100%;
        min-height: 48px;
        border: 1px solid rgba(17, 24, 39, 0.14);
        border-radius: var(--radius);
        background: #fff;
        color: var(--ink);
        font: inherit;
        font-size: 0.96rem;
        font-weight: 700;
        padding: 0 14px;
        outline: none;
      }

      .route-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(28, 105, 212, 0.12);
      }

      .route-btn {
        min-height: 48px;
        padding: 0 18px;
        border: none;
        border-radius: var(--radius);
        background: var(--accent);
        color: #fff;
        font: inherit;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        cursor: pointer;
        transition: transform 0.2s ease, background 0.2s ease;
      }

      .route-btn:hover {
        background: var(--accent-dark);
        transform: translateY(-1px);
      }

      .route-btn:disabled {
        background: #8792a2;
        cursor: not-allowed;
        transform: none;
      }

      .route-btn.secondary {
        background: #e7ebf0;
        color: var(--ink);
      }

      .route-btn.secondary:hover {
        background: #dce2ea;
      }

      .route-status {
        margin: 16px 0 0;
        min-height: 22px;
        color: var(--muted);
        font-size: 0.94rem;
        font-weight: 700;
      }

      .route-status.error {
        color: #b42318;
      }

      .route-status.success {
        color: #087443;
      }

      .route-result {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
        margin: 18px 0 0;
        opacity: 0;
        transform: translateY(8px);
        transition: opacity 0.35s ease, transform 0.35s ease;
        pointer-events: none;
      }

      .route-result.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .result-card {
        border-left: 3px solid var(--accent);
        background: #fff;
        padding: 13px 14px;
      }

      .result-card span {
        display: block;
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.11em;
        text-transform: uppercase;
        margin-bottom: 4px;
      }

      .result-card strong {
        display: block;
        color: var(--ink);
        font-size: 1rem;
        line-height: 1.3;
      }

      .map-frame {
        min-height: 640px;
        border-radius: var(--radius);
        overflow: hidden;
        background: #101722;
        box-shadow: var(--shadow);
      }

      #map {
        width: 100%;
        height: 640px;
        background: #101722;
      }

      .bmw-marker {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #0f172a;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.55);
        transform: translateY(50%);
        border: 2px solid rgba(255, 255, 255, 0.08);
      }

      .bmw-marker img {
        width: 40px;
        height: 40px;
      }

      .car-marker {
        width: 34px;
        height: 52px;
        transform: translateY(50%) rotate(var(--bearing, 0deg));
        transition: transform 0.08s linear;
        will-change: transform;
        filter: drop-shadow(0 3px 6px rgba(0, 0, 0, 0.6));
      }

      .car-marker.hidden {
        display: none;
      }

      .no-key {
        margin-top: 40px;
        padding: 56px 32px;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--paper);
        color: var(--muted);
        text-align: center;
      }

      .no-key h3 {
        margin: 0 0 10px;
        color: var(--ink);
      }

      .no-key code {
        background: #e7ebf0;
        padding: 4px 8px;
        border-radius: 5px;
        color: var(--accent-dark);
      }

      .site-footer {
        background: #070b10;
        color: rgba(255, 255, 255, 0.74);
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        padding: 34px 0;
      }

      .footer-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 28px;
        align-items: end;
      }

      .footer-brand {
        display: grid;
        gap: 8px;
      }

      .footer-brand strong {
        color: #fff;
        font-size: 1rem;
        font-weight: 700;
      }

      .footer-brand span,
      .footer-legal {
        font-size: 0.82rem;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 16px;
      }

      .footer-links a {
        color: rgba(255, 255, 255, 0.78);
        text-decoration: none;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .footer-links a:hover {
        color: #fff;
      }

      @media (max-width: 980px) {
        .site-nav {
          align-items: flex-start;
          flex-direction: column;
        }

        .brand {
          min-width: 0;
        }

        .nav-links {
          justify-content: flex-start;
        }

        .atelier-board,
        .route-layout {
          grid-template-columns: 1fr;
        }

        .order-sheet {
          border-right: 0;
          border-bottom: 1px solid var(--line);
        }

        .model-stage {
          min-height: 520px;
        }

        .stage-caption {
          grid-template-columns: 1fr;
        }

        .stage-coordinates {
          width: max-content;
          padding-left: 0;
          padding-top: 14px;
          border-left: 0;
          border-top: 1px solid rgba(255, 255, 255, 0.28);
        }

        .heritage-content {
          grid-template-columns: 1fr;
        }

        .heritage-mark {
          justify-self: start;
          text-align: left;
        }
      }

      @media (max-width: 720px) {
        .page-shell,
        .site-nav {
          width: min(100% - 28px, 1180px);
        }

        .site-nav {
          top: 14px;
          padding: 12px;
        }

        .nav-links a {
          min-height: 34px;
          padding: 0 9px;
          font-size: 0.72rem;
        }

        .hero-overlay {
          padding-top: 180px;
        }

        .scroll-hint {
          display: none;
        }

        .experience-section,
        .route-section {
          padding: 64px 0;
        }

        .atelier-board {
          margin-top: 34px;
        }

        .order-sheet {
          padding: 24px;
        }

        .spec-row,
        .service-rail,
        .heritage-ledger {
          grid-template-columns: 1fr;
        }

        .model-stage {
          min-height: 500px;
        }

        .model-picks {
          left: 18px;
          right: auto;
          top: 50px;
        }

        .heritage-section {
          min-height: 660px;
        }

        .heritage-video {
          width: 100%;
          opacity: 0.34;
        }

        .heritage-content {
          padding: 76px 0;
        }

        .ledger-item,
        .ledger-item + .ledger-item {
          padding: 18px 0;
          border-right: 0;
          border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        }

        .ledger-item:last-child {
          border-bottom: 0;
        }

        .route-panel {
          padding: 18px;
        }

        .route-meta div {
          grid-template-columns: 1fr;
          gap: 3px;
        }

        .map-frame {
          min-height: 430px;
        }

        #map {
          height: 430px;
        }

        .footer-grid {
          grid-template-columns: 1fr;
        }

        .footer-links {
          justify-content: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <section class="hero">
      <video class="hero-video" autoplay muted loop playsinline preload="auto">
        <source src="https://www.bmw-m.com/content/dam/bmw/marketBMW_M/www_bmw-m_com/fastlane/area-m/home/Stage_Loop_Querformat.mp4" type="video/mp4">
      </video>

      <nav class="site-nav" aria-label="Hauptnavigation">
        <a class="brand" href="/">
          <strong>Bayerische Motoren Werke AG</strong>
          <span>Seit 1916</span>
        </a>
        <div class="nav-links">
          <a href="/" class="active">Home</a>
          <a href="/car-configurator">Konfigurator</a>
          <a href="/merch-shop">Merchandise</a>
          <a href="/ai-feature">KI</a>
          <a href="/shopping-cart">Warenkorb</a>
        </div>
      </nav>

      <div class="hero-overlay">
        <h1 class="hero-title">Road zu deinem<br>Supercar</h1>
        <p class="hero-subtitle">Die Reise beginnt jetzt</p>
        <a class="hero-cta" href="/car-configurator">Jetzt konfigurieren</a>
        <div class="scroll-hint">Scroll</div>
      </div>
    </section>

    <main>
      <section class="experience-section" id="experience">
        <div class="page-shell">
          <p class="section-kicker">Werkauftrag 01</p>
          <h2 class="section-title">Vom ersten Strich zur eigenen Linie.</h2>
          <p class="section-copy">Die Startseite arbeitet wie ein kuratierter Auftrag: erst das Fahrzeug festlegen, dann Beratung, Ausstattung und Route anschließen.</p>

          <div class="atelier-board">
            <article class="order-sheet">
              <div>
                <div class="doc-meta" aria-label="Konfigurator Status">
                  <span>Bayerische Motoren Werke AG</span>
                  <span>Konfiguration</span>
                  <span>München</span>
                </div>
                <h3>Fahrzeug als Handschrift.</h3>
                <p class="order-copy">Kein Kataloggefühl. Der Konfigurator wird zum ersten Werkstück: Modell, Farbe und Ausstattung werden bewusst gesetzt.</p>

                <div class="spec-table" aria-label="Konfigurator Details">
                  <div class="spec-row">
                    <span>Modelle</span>
                    <strong>BMW 3er und BMW X5</strong>
                  </div>
                  <div class="spec-row">
                    <span>Ausrichtung</span>
                    <strong>Präzise Auswahl statt endloser Produktwand</strong>
                  </div>
                  <div class="spec-row">
                    <span>Nächster Schritt</span>
                    <strong>Konfiguration speichern und in den Warenkorb übernehmen</strong>
                  </div>
                </div>
              </div>

              <div class="action-row">
                <a class="button primary" href="/car-configurator">Konfigurator starten</a>
                <a class="button outline" href="/ai-feature">Beratung anfragen</a>
              </div>
            </article>

            <aside class="model-stage" aria-label="Modellbühne">
              <img src="/home/static/images/x5-hero.webp" alt="BMW X5 Frontansicht" loading="lazy">
              <span class="stage-index">Aktueller Fokus</span>
              <div class="model-picks" aria-label="Schnelle Modellwahl">
                <a href="/car-configurator?model=3er">3er Linie</a>
                <a href="/car-configurator?model=x5">X5 Linie</a>
              </div>
              <div class="stage-caption">
                <div>
                  <h4>Eine Bühne, zwei Charaktere.</h4>
                  <p>Sportliche Limousine oder souveräner SUV. Die Seite führt nicht in eine Liste, sondern in eine Entscheidung.</p>
                </div>
                <div class="stage-coordinates">
                  MUC 48.1769<br>
                  AG 1916
                </div>
              </div>
            </aside>
          </div>

          <div class="service-rail" aria-label="Weitere Einstiege">
            <a class="service-link" href="/ai-feature">
              <span class="service-number">02</span>
              <h3>KI Beratung</h3>
              <p>Aus einem Alltagssatz wird ein konkreter Vorschlag für Fahrzeug und Zubehör.</p>
            </a>
            <a class="service-link" href="/merch-shop">
              <span class="service-number">03</span>
              <h3>Merchandise</h3>
              <p>Ausgewählte Begleiter für Fahrt, Reise und Alltag.</p>
            </a>
            <a class="service-link" href="#route-planner">
              <span class="service-number">04</span>
              <h3>Route zur BMW Welt</h3>
              <p>Der Weg nach München bleibt Teil der Experience, aber ohne laute Oberfläche.</p>
            </a>
          </div>
        </div>
      </section>

      <section class="heritage-section" aria-label="Heritage">
        <video class="heritage-video" autoplay muted loop playsinline preload="metadata">
          <source src="https://www.bmwgroup.com/content/dam/grpw/websites/bmwgroup_com/company/produktion/videos/240419_Group_Produktion_Header_2560x896.mp4" type="video/mp4">
        </video>
        <div class="page-shell heritage-content">
          <div>
            <p class="section-kicker">Archiv und Zukunft</p>
            <h2 class="heritage-title">Nicht nostalgisch. Verwurzelt.</h2>
            <p class="heritage-copy">Bayerische Motoren Werke AG steht hier nicht als Retro-Geste, sondern als Herkunft für moderne Entscheidungen: klare Linien, technische Ruhe, sichtbare Präzision.</p>

            <div class="heritage-ledger">
              <div class="ledger-item">
                <span>Handwerk</span>
                <strong>Details, die sich nicht vordrängen.</strong>
              </div>
              <div class="ledger-item">
                <span>Technik</span>
                <strong>Auswahl mit nachvollziehbarer Logik.</strong>
              </div>
              <div class="ledger-item">
                <span>Zukunft</span>
                <strong>Digitale Beratung als Teil der Journey.</strong>
              </div>
            </div>
          </div>

          <div class="heritage-mark" aria-label="Gründungsjahr">
            <strong>1916</strong>
            <span>Aus Bayern<br>für morgen</span>
          </div>
        </div>
      </section>

      <section class="route-section" id="route-planner">
        <div class="page-shell">
          <p class="section-kicker">Route</p>
          <h2 class="section-title" id="routeTitle">Dein Ziel: BMW Welt München</h2>
          <p class="section-copy">Ein ruhiger Planungsbereich für deine Fahrt nach München. Standort nutzen, Adresse eingeben, Route starten.</p>

          <% if (mapsApiKey) { %>
            <div class="route-layout">
              <aside class="route-panel">
                <h3>Route planen</h3>
                <p>Die Fahrstrecke wird mit Google Maps berechnet und direkt auf der Karte visualisiert.</p>

                <div class="route-meta" aria-label="Zieldaten">
                  <div>
                    <span>Ziel</span>
                    <strong>BMW Welt München</strong>
                  </div>
                  <div>
                    <span>Adresse</span>
                    <strong>Am Olympiapark 1, 80809 München</strong>
                  </div>
                </div>

                <form class="controls" id="routeForm">
                  <div class="route-field">
                    <label for="startAddress">Startadresse</label>
                    <input class="route-input" id="startAddress" name="startAddress" type="text" autocomplete="street-address" placeholder="Adresse eingeben oder Standort nutzen">
                  </div>
                  <button class="route-btn secondary" id="locationBtn" type="button">Standort nutzen</button>
                  <button class="route-btn" id="routeBtn" type="submit" disabled>Route starten</button>
                </form>

                <p class="route-status" id="routeStatus" aria-live="polite"></p>

                <div class="route-result" id="routeResult" aria-live="polite">
                  <div class="result-card">
                    <span>Ziel</span>
                    <strong id="resultDestination">-</strong>
                  </div>
                  <div class="result-card">
                    <span>Distanz</span>
                    <strong id="resultDistance">-</strong>
                  </div>
                  <div class="result-card">
                    <span>Fahrtdauer</span>
                    <strong id="resultDuration">-</strong>
                  </div>
                </div>
              </aside>

              <div class="map-frame">
                <div id="map"></div>
              </div>
            </div>

            <script>
              const DEFAULT_CENTER = { lat: 51.1657, lng: 10.4515 };
              const BMW_LOGO_URL =
                "https://www.bmw-welt.com/content/dam/bmw/common/images/logo-icons/BMW/BMW_White_Logo.svg.asset.1670245093434.svg";

              const CAR_SVG =
                '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 90" width="34" height="52">' +
                  '<rect x="10" y="8" width="40" height="74" rx="12" fill="#1C69D4" stroke="#fff" stroke-width="2"/>' +
                  '<rect x="16" y="16" width="28" height="20" rx="4" fill="#cfe8ff" opacity="0.85"/>' +
                  '<rect x="16" y="54" width="28" height="20" rx="4" fill="#1a5196"/>' +
                  '<circle cx="16" cy="12" r="2.2" fill="#fff59d"/>' +
                  '<circle cx="44" cy="12" r="2.2" fill="#fff59d"/>' +
                  '<circle cx="16" cy="78" r="2" fill="#ef5350"/>' +
                  '<circle cx="44" cy="78" r="2" fill="#ef5350"/>' +
                '</svg>';

              let map, directionsService, directionsRenderer;
              let AdvancedMarkerElementCtor;
              let carMarker, carContent, destinationMarker;
              let animationFrame = null;
              let destinations = [];
              let currentLocationOrigin = null;

              async function initMap() {
                const { Map } = await google.maps.importLibrary("maps");
                const { AdvancedMarkerElement } = await google.maps.importLibrary("marker");
                AdvancedMarkerElementCtor = AdvancedMarkerElement;

                map = new Map(document.getElementById("map"), {
                  zoom: 6,
                  center: DEFAULT_CENTER,
                  mapId: "DEMO_MAP_ID",
                  colorScheme: "DARK",
                  disableDefaultUI: false,
                });

                directionsService = new google.maps.DirectionsService();
                directionsRenderer = new google.maps.DirectionsRenderer({
                  suppressMarkers: true,
                  polylineOptions: {
                    strokeColor: "#8FC0FF",
                    strokeOpacity: 0.95,
                    strokeWeight: 5,
                  },
                });
                directionsRenderer.setMap(map);

                carContent = document.createElement("div");
                carContent.className = "car-marker hidden";
                carContent.innerHTML = CAR_SVG;

                carMarker = new AdvancedMarkerElement({
                  position: DEFAULT_CENTER,
                  map: map,
                  content: carContent,
                });

                await loadDestinations();
              }

              function setStatus(message, type) {
                const status = document.getElementById("routeStatus");
                status.textContent = message || "";
                status.className = "route-status" + (type ? " " + type : "");
              }

              function selectedDestination() {
                return destinations[0] || null;
              }

              async function loadDestinations() {
                const routeBtn = document.getElementById("routeBtn");

                try {
                  const response = await fetch("/api/destinations");
                  if (!response.ok) throw new Error("Destinations request failed");
                  destinations = await response.json();

                  routeBtn.disabled = destinations.length === 0;
                  updateRouteTitle();
                  setStatus(destinations.length ? "Route zur BMW Welt starten." : "BMW Welt Ziel nicht verfügbar.", destinations.length ? "" : "error");
                } catch (err) {
                  console.error(err);
                  routeBtn.disabled = true;
                  setStatus("BMW Welt konnte nicht geladen werden.", "error");
                }
              }

              function updateRouteTitle() {
                const destination = selectedDestination();
                document.getElementById("routeTitle").textContent = destination
                  ? `Dein Ziel: ${destination.name || destination.label}`
                  : "Dein Ziel: BMW Welt München";
              }

              function updateDestinationMarker(position, title) {
                if (!AdvancedMarkerElementCtor || !position) return;

                const markerContent = document.createElement("div");
                markerContent.className = "bmw-marker";
                markerContent.innerHTML = '<img src="' + BMW_LOGO_URL + '" alt="">';

                if (destinationMarker) {
                  destinationMarker.map = null;
                }

                destinationMarker = new AdvancedMarkerElementCtor({
                  position,
                  map,
                  title,
                  content: markerContent,
                });

                destinationMarker.addListener("click", () => {
                  const streetView = map.getStreetView();
                  streetView.setPosition(position);
                  streetView.setPov({ heading: 265, pitch: 0 });
                  streetView.setVisible(true);
                });
              }

              function animateCar(path) {
                if (!path || path.length < 2) return;
                if (animationFrame) cancelAnimationFrame(animationFrame);

                carContent.classList.remove("hidden");

                const DRIVE_DURATION = 8000;
                const ZOOM_DURATION = 1500;
                const FINAL_ZOOM = 16;

                const startZoom = map.getZoom();
                const start = performance.now();

                function easeInOutCubic(x) {
                  return x < 0.5 ? 4 * x * x * x : 1 - Math.pow(-2 * x + 2, 3) / 2;
                }

                function positionAt(progress) {
                  const idx = progress * (path.length - 1);
                  const i = Math.floor(idx);
                  const frac = idx - i;
                  const p1 = path[i];
                  const p2 = path[Math.min(i + 1, path.length - 1)];
                  return {
                    lat: p1.lat() + (p2.lat() - p1.lat()) * frac,
                    lng: p1.lng() + (p2.lng() - p1.lng()) * frac,
                    bearing: Math.atan2(p2.lng() - p1.lng(), p2.lat() - p1.lat()) * 180 / Math.PI,
                  };
                }

                function step(now) {
                  const elapsed = now - start;

                  if (elapsed < DRIVE_DURATION) {
                    const progress = easeInOutCubic(elapsed / DRIVE_DURATION);
                    const pos = positionAt(progress);
                    carMarker.position = { lat: pos.lat, lng: pos.lng };
                    carContent.style.setProperty("--bearing", pos.bearing + "deg");
                    animationFrame = requestAnimationFrame(step);
                  } else {
                    const destination = selectedDestination();
                    carMarker.position = path[path.length - 1];
                    animationFrame = null;
                    zoomIn(performance.now(), path[path.length - 1], destination ? destination.name : "BMW Ziel");
                  }
                }

                function zoomIn(zoomStart, destinationPosition, destinationTitle) {
                  function zoomStep(now) {
                    const t = Math.min(1, (now - zoomStart) / ZOOM_DURATION);
                    const eased = easeInOutCubic(t);
                    map.setZoom(startZoom + eased * (FINAL_ZOOM - startZoom));
                    map.setCenter(destinationPosition);
                    if (t < 1) animationFrame = requestAnimationFrame(zoomStep);
                    else {
                      updateDestinationMarker(destinationPosition, destinationTitle);
                      animationFrame = null;
                    }
                  }
                  animationFrame = requestAnimationFrame(zoomStep);
                }

                animationFrame = requestAnimationFrame(step);
              }

              function requestCurrentLocation() {
                return new Promise((resolve, reject) => {
                  if (!navigator.geolocation) {
                    reject(new Error("Geolocation wird von diesem Browser nicht unterstützt."));
                    return;
                  }

                  navigator.geolocation.getCurrentPosition(
                    (pos) => {
                      resolve({ lat: pos.coords.latitude, lng: pos.coords.longitude });
                    },
                    () => reject(new Error("Standortzugriff wurde verweigert.")),
                    { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
                  );
                });
              }

              async function resolveOrigin() {
                const input = document.getElementById("startAddress");
                const manualOrigin = input.value.trim();

                if (manualOrigin) {
                  currentLocationOrigin = null;
                  return manualOrigin;
                }

                if (currentLocationOrigin) {
                  return currentLocationOrigin;
                }

                setStatus("Standort wird ermittelt...", "");
                currentLocationOrigin = await requestCurrentLocation();
                input.placeholder = "Aktueller Standort wird verwendet";
                return currentLocationOrigin;
              }

              async function calculateRoute() {
                const destination = selectedDestination();
                const routeBtn = document.getElementById("routeBtn");
                const resultBox = document.getElementById("routeResult");

                if (!destination) {
                  setStatus("BMW Welt ist gerade nicht verfügbar.", "error");
                  return;
                }

                routeBtn.disabled = true;
                resultBox.classList.remove("visible");
                setStatus("Route wird berechnet...", "");

                try {
                  const origin = await resolveOrigin();

                  directionsService.route({
                    origin,
                    destination: destination.destination || destination.value,
                    travelMode: google.maps.TravelMode.DRIVING,
                  }, (result, status) => {
                    routeBtn.disabled = false;

                    if (status === "OK") {
                      directionsRenderer.setDirections(result);
                      const route = result.routes[0];
                      const leg = route.legs[0];

                      document.getElementById("resultDestination").textContent = destination.name || destination.label || "BMW Ziel";
                      document.getElementById("resultDistance").textContent = leg.distance ? leg.distance.text : "-";
                      document.getElementById("resultDuration").textContent = leg.duration ? leg.duration.text : "-";
                      resultBox.classList.add("visible");
                      setStatus(`Route zu ${destination.name || destination.label} ist bereit.`, "success");

                      updateDestinationMarker(leg.end_location, destination.name || destination.label);
                      animateCar(route.overview_path);
                    } else {
                      setStatus("Route konnte nicht berechnet werden: " + status, "error");
                    }
                  });
                } catch (err) {
                  routeBtn.disabled = false;
                  setStatus(err.message + " Bitte Startadresse eingeben.", "error");
                  document.getElementById("startAddress").focus();
                }
              }

              document.getElementById("startAddress").addEventListener("input", () => {
                currentLocationOrigin = null;
              });

              document.getElementById("locationBtn").addEventListener("click", async () => {
                const btn = document.getElementById("locationBtn");
                const input = document.getElementById("startAddress");
                btn.disabled = true;
                setStatus("Standort wird ermittelt...", "");

                try {
                  currentLocationOrigin = await requestCurrentLocation();
                  input.value = "";
                  input.placeholder = "Aktueller Standort wird verwendet";
                  setStatus("Standort erkannt. Du kannst die Route starten.", "success");
                } catch (err) {
                  setStatus(err.message + " Bitte Startadresse eingeben.", "error");
                  input.focus();
                } finally {
                  btn.disabled = false;
                }
              });

              document.getElementById("routeForm").addEventListener("submit", (event) => {
                event.preventDefault();
                calculateRoute();
              });
            </script>
            <script src="https://maps.googleapis.com/maps/api/js?key=<%= mapsApiKey %>&libraries=marker&v=weekly&callback=initMap" async defer></script>
          <% } else { %>
            <div class="no-key">
              <h3>API-Key erforderlich</h3>
              <p>Bitte konfigurieren Sie den <code>GOOGLE_MAPS_API_KEY</code> in Ihrer Umgebung.</p>
            </div>
          <% } %>
        </div>
      </section>
    </main>

    <footer class="site-footer" id="impressum">
      <div class="page-shell footer-grid">
        <div class="footer-brand">
          <strong>Bayerische Motoren Werke AG</strong>
          <span>Studentisches Cloud-Web-Projekt mit Konfigurator, Merchandise, KI-Beratung und Route.</span>
          <span class="footer-legal">Impressum: BMW Cloud Web App Team, Cloud Based Web Development, München.</span>
          <span class="footer-legal">© 2026 Bayerische Motoren Werke AG Experience. Hochschulprojekt.</span>
        </div>
        <nav class="footer-links" aria-label="Footer Navigation">
          <a href="/">Home</a>
          <a href="/car-configurator">Konfigurator</a>
          <a href="/merch-shop">Merchandise</a>
          <a href="/ai-feature">KI</a>
          <a href="#impressum">Impressum</a>
        </nav>
      </div>
    </footer>

    <script>
      (function () {
        const experience = document.querySelector('.experience-section');
        let snapping = false;

        window.addEventListener('wheel', function (event) {
          if (!experience || snapping) return;
          const experienceTop = experience.offsetTop;
          if (window.scrollY < experienceTop && event.deltaY > 0) {
            snapping = true;
            event.preventDefault();
            window.scrollTo({ top: experienceTop, behavior: 'smooth' });
            setTimeout(function () { snapping = false; }, 900);
          }
        }, { passive: false });
      })();
    </script>
  </body>
</html>
