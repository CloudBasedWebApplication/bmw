<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Car Configurator</title>
    <style>
      :root {
        --bg: #f3f5f7;
        --panel: #ffffff;
        --text: #111111;
        --muted: #5c6670;
        --accent: #0066b1;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(0, 102, 177, 0.12), transparent 30%),
          linear-gradient(180deg, #fafbfc 0%, var(--bg) 100%);
        color: var(--text);
      }

      main {
        width: min(800px, calc(100% - 32px));
        padding: 40px;
        border-radius: 24px;
        background: var(--panel);
        box-shadow: 0 18px 48px rgba(17, 17, 17, 0.08);
      }

      h1 {
        margin: 0 0 24px;
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        line-height: 1;
      }

      .car-image {
        width: 100%;
        border-radius: 16px;
        overflow: hidden;
      }

      .car-image img {
        width: 100%;
        display: block;
        object-fit: cover;
      }

      p {
        margin: 16px 0 0;
        font-size: 1rem;
        color: var(--muted);
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Car Configurator</h1>
      <div class="car-image">
        <img
          src="<%= minioBaseUrl %>/configurator/3BMWBlackFamily.webp"
          alt="BMW 3er – Schwarz"
        />
      </div>
      <p>Bild geladen aus MinIO: <code><%= minioBaseUrl %>/configurator/</code></p>
    </main>
  </body>
</html>
