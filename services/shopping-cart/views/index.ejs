<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BMW Warenkorb | Ihr Gateway</title>
    <style>
      @font-face {
        font-family: 'BMWTypeNext';
        font-style: normal; font-weight: 200; font-display: swap;
        src: url('/home/static/fonts/BMWTypeNextLatin-Thin.woff2') format('woff2'),
             url('/home/static/fonts/BMWTypeNextLatin-Thin.woff') format('woff');
      }
      @font-face {
        font-family: 'BMWTypeNext';
        font-style: normal; font-weight: 400; font-display: swap;
        src: url('/home/static/fonts/BMWTypeNextLatin-Light.woff2') format('woff2'),
             url('/home/static/fonts/BMWTypeNextLatin-Light.woff') format('woff');
      }
      @font-face {
        font-family: 'BMWTypeNext';
        font-style: normal; font-weight: 700; font-display: swap;
        src: url('/home/static/fonts/BMWTypeNextLatin-Bold.woff2') format('woff2'),
             url('/home/static/fonts/BMWTypeNextLatin-Bold.woff') format('woff');
      }

      :root {
        --accent: #1c69d4;
        --accent-dark: #114a96;
        --bg: #f6f7f9;
        --panel: #ffffff;
        --text: #111827;
        --muted: #697386;
        --danger: #ef4444;
        --radius: 8px;
        --shadow: 0 20px 55px rgba(16, 24, 40, 0.12);
        --line: rgba(17, 24, 39, 0.12);
      }

      * { box-sizing: border-box; -webkit-font-smoothing: antialiased; }

      body {
        margin: 0;
        font-family: 'BMWTypeNext', 'Inter', -apple-system, system-ui, sans-serif;
        background:
          linear-gradient(rgba(17, 24, 39, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(17, 24, 39, 0.045) 1px, transparent 1px),
          var(--bg);
        background-size: 44px 44px;
        color: var(--text);
        line-height: 1.5;
      }

      .nav-outer {
        position: sticky; top: 0; z-index: 50;
        padding: 20px 20px 0;
        pointer-events: none;
      }
      .site-nav {
        pointer-events: auto;
        width: min(1180px, 100%); margin: 0 auto;
        min-height: 64px; display: flex; align-items: center;
        justify-content: space-between; gap: 24px;
        padding: 12px 14px 12px 20px;
        color: #fff;
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 8px;
        background: rgba(7,12,18,0.92);
        backdrop-filter: blur(18px);
        box-shadow: 0 16px 40px rgba(0,0,0,0.25);
      }
      .brand {
        text-decoration: none; color: #fff;
        display: flex; flex-direction: column; gap: 2px;
      }
      .brand strong { font-size: 0.9rem; font-weight: 700; }
      .brand span { font-size: 0.7rem; opacity: 0.5; letter-spacing: 0.04em; }
      .nav-links { display: flex; gap: 4px; flex-wrap: wrap; }
      .nav-links a {
        text-decoration: none; color: rgba(255,255,255,0.65); padding: 8px 16px;
        border-radius: 6px; font-size: 0.85rem; font-weight: 500; transition: 0.2s;
      }
      .nav-links a.active, .nav-links a:hover { background: rgba(255,255,255,0.1); color: #fff; }

      .layout { max-width: 800px; margin: 0 auto; padding: 40px 20px; }
      h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; letter-spacing: 0; line-height: 1.02; margin: 0; }

      .empty-state {
        text-align: center; padding: 80px 40px; background: var(--panel);
        border-radius: var(--radius); box-shadow: var(--shadow);
      }
      .empty-state p { color: var(--muted); margin-bottom: 24px; font-size: 1.1rem; }
      .btn-primary {
        display: inline-block; padding: 12px 28px; background: var(--accent);
        color: white; text-decoration: none; border-radius: var(--radius);
        font-weight: 700; font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase;
        transition: 0.3s; font-family: inherit; border: none; cursor: pointer;
      }
      .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(28,105,212,0.25); }

      .item {
        background: var(--panel); border-radius: var(--radius);
        padding: 20px; display: flex; gap: 20px; align-items: center;
        margin-bottom: 12px; border: 1px solid var(--line);
        box-shadow: var(--shadow); transition: transform 0.2s;
      }
      .item:hover { transform: scale(1.01); }

      .item img {
        width: 120px; height: 90px; object-fit: cover;
        border-radius: var(--radius); background: #f8fafc; flex-shrink: 0;
      }

      .item-info { flex: 1; }
      .item-name { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; color: var(--text); }
      .item-meta {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.05em; color: var(--accent);
      }
      .item-quantity { font-size: 0.85rem; color: var(--muted); margin-top: 4px; }
      .item-variant { font-size: 0.85rem; color: var(--muted); margin-top: 6px; }

      .item-right { text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
      .item-price { font-weight: 800; color: var(--text); font-size: 1.1rem; }

      .remove-btn {
        background: #fee2e2; border: none; color: var(--danger);
        padding: 6px 12px; border-radius: var(--radius); cursor: pointer;
        font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
        transition: 0.2s; font-family: inherit;
      }
      .remove-btn:hover { background: var(--danger); color: white; }

      .qty-controls {
        display: flex; align-items: center; gap: 8px; margin-top: 4px;
      }
      .qty-btn {
        width: 28px; height: 28px; border: 1px solid var(--line); background: #f8fafc;
        border-radius: var(--radius); cursor: pointer; font-size: 1rem; font-weight: 700;
        color: var(--text); display: flex; align-items: center; justify-content: center;
        transition: 0.2s; padding: 0; font-family: inherit;
      }
      .qty-btn:hover { background: var(--accent); color: white; border-color: var(--accent); }
      .qty-btn:disabled { opacity: 0.4; cursor: default; }
      .qty-value { font-size: 0.95rem; font-weight: 700; min-width: 20px; text-align: center; }

      .summary {
        margin-top: 24px; padding: 32px; background: #0b0f14;
        border-radius: var(--radius); color: white;
        display: flex; justify-content: space-between; align-items: center;
        box-shadow: 0 20px 40px rgba(0,0,0,0.18);
      }
      .total-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.6; }
      .total-value { font-size: 2rem; font-weight: 700; letter-spacing: -0.01em; }

      .btn-ghost {
        display: inline-block; padding: 10px 20px; background: transparent;
        color: var(--muted); border: 1px solid var(--line); border-radius: var(--radius);
        font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
        cursor: pointer; transition: 0.2s; font-family: inherit; text-decoration: none;
      }
      .btn-ghost:hover { border-color: var(--danger); color: var(--danger); background: #fff5f5; }

      .loading { text-align: center; padding: 40px; color: var(--muted); font-weight: 500; }

      /* ── Checkout ── */
      .checkout-view, .confirmation-view { display: none; }
      .checkout-view.active, .confirmation-view.active { display: block; }

      .step-bar {
        display: flex; align-items: center; margin-bottom: 36px;
      }
      .step {
        display: flex; align-items: center; gap: 10px;
        font-size: 0.82rem; font-weight: 600; color: var(--muted);
      }
      .step.active { color: var(--accent); }
      .step.done { color: #16a34a; }
      .step-num {
        width: 28px; height: 28px; border-radius: 50%;
        border: 2px solid currentColor;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.75rem; font-weight: 800; flex-shrink: 0;
      }
      .step-line { flex: 1; height: 1px; background: #e2e8f0; margin: 0 14px; }

      .form-card {
        background: var(--panel); border-radius: var(--radius);
        box-shadow: var(--shadow); padding: 32px; margin-bottom: 16px;
        border: 1px solid var(--line);
      }
      .form-card h2 { font-size: 1.1rem; font-weight: 700; letter-spacing: 0; margin: 0 0 24px; }
      .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
      .form-group:last-child { margin-bottom: 0; }
      .form-group label {
        font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.08em; color: var(--muted);
      }
      .form-group input, .form-group select {
        padding: 12px 14px; border: 1px solid var(--line); border-radius: var(--radius);
        font-size: 0.95rem; font-family: inherit; color: var(--text);
        background: #fafbfc; outline: none; transition: border-color 0.2s;
      }
      .form-group input:focus, .form-group select:focus { border-color: var(--accent); }

      .payment-options { display: flex; flex-direction: column; gap: 10px; }
      .payment-option {
        display: flex; align-items: center; gap: 14px; padding: 14px 18px;
        border: 1px solid var(--line); border-radius: var(--radius); cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
      }
      .payment-option:has(input:checked) { border-color: var(--accent); background: rgba(28,105,212,0.04); }
      .payment-option input { accent-color: var(--accent); }
      .payment-option-label { font-weight: 600; font-size: 0.92rem; }
      .payment-option-sub { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

      .order-summary-card {
        background: var(--panel); border-radius: var(--radius);
        box-shadow: var(--shadow); padding: 24px 28px; margin-bottom: 24px;
        border: 1px solid var(--line);
      }
      .order-summary-card h3 { font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin: 0 0 16px; }
      .summary-line {
        display: flex; justify-content: space-between; align-items: center;
        padding: 9px 0; border-bottom: 1px solid var(--line);
        font-size: 0.88rem;
      }
      .summary-line:last-child { border-bottom: none; font-weight: 800; font-size: 1rem; padding-top: 14px; }
      .summary-line-name { color: var(--text); }
      .summary-line-price { font-weight: 700; color: var(--text); }

      .btn-back {
        background: none; border: 1px solid var(--line); color: var(--muted);
        padding: 11px 22px; border-radius: var(--radius); font-size: 0.78rem;
        font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
        cursor: pointer; transition: 0.2s; font-family: inherit;
      }
      .btn-back:hover { border-color: var(--text); color: var(--text); }

      /* ── Confirmation ── */
      .confirmation-card {
        background: var(--panel); border-radius: var(--radius);
        box-shadow: var(--shadow); padding: 64px 40px; text-align: center;
        border: 1px solid var(--line);
      }
      .confirm-icon {
        width: 72px; height: 72px; border-radius: 50%; background: #16a34a;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 28px;
      }
      .confirm-icon::after {
        content: ''; display: block;
        width: 18px; height: 30px;
        border-right: 3px solid white; border-bottom: 3px solid white;
        transform: rotate(45deg) translate(-2px, -3px);
      }
      .confirmation-card h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 700; letter-spacing: 0; line-height: 1.02; margin: 0 0 14px; }
      .confirmation-card .conf-sub { color: var(--muted); font-size: 1rem; margin: 0 0 6px; }
      .conf-order-nr { font-size: 0.88rem; font-weight: 700; color: var(--accent); margin-top: 8px; }
      .confirmation-actions { margin-top: 40px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

      @media (max-width: 600px) {
        .form-row { grid-template-columns: 1fr; }
        .confirmation-card { padding: 40px 24px; }
      }
    </style>
  </head>
  <body>
    <div class="nav-outer">
      <nav class="site-nav" aria-label="Hauptnavigation">
        <a class="brand" href="/"><strong>Bayerische Motoren Werke AG</strong><span>Seit 1916</span></a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/car-configurator">Konfigurator</a>
          <a href="/merch-shop">Merchandise</a>
          <a href="/ai-feature">KI</a>
          <a href="/shopping-cart" class="active">Warenkorb</a>
        </div>
      </nav>
    </div>

    <div class="layout">

      <!-- Cart -->
      <div id="cartWrapper">
        <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:32px;">
          <h1 style="margin:0;">Ihr Warenkorb</h1>
          <button class="btn-ghost" id="clearCartBtn">Warenkorb leeren</button>
        </div>
        <div id="cartContent">
          <div class="loading">Inhalt wird sicher geladen...</div>
        </div>
      </div>

      <!-- Checkout -->
      <div class="checkout-view" id="checkoutView">
        <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:32px;">
          <h1 style="margin:0;">Kasse</h1>
          <button class="btn-back" onclick="showCart()">← Zurück zum Warenkorb</button>
        </div>

        <div class="step-bar">
          <div class="step active" id="step1"><span class="step-num">1</span> Lieferadresse</div>
          <div class="step-line"></div>
          <div class="step" id="step2"><span class="step-num">2</span> Zahlung</div>
          <div class="step-line"></div>
          <div class="step" id="step3"><span class="step-num">3</span> Bestätigung</div>
        </div>

        <div class="form-card">
          <h2>Lieferadresse</h2>
          <div class="form-row">
            <div class="form-group">
              <label>Vorname</label>
              <input type="text" id="firstName" placeholder="Max" autocomplete="given-name" />
            </div>
            <div class="form-group">
              <label>Nachname</label>
              <input type="text" id="lastName" placeholder="Mustermann" autocomplete="family-name" />
            </div>
          </div>
          <div class="form-group">
            <label>E-Mail-Adresse</label>
            <input type="email" id="emailField" placeholder="max@example.de" autocomplete="email" />
          </div>
          <div class="form-group">
            <label>Straße und Hausnummer</label>
            <input type="text" id="street" placeholder="Musterstraße 42" autocomplete="street-address" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Postleitzahl</label>
              <input type="text" id="zip" placeholder="80809" autocomplete="postal-code" />
            </div>
            <div class="form-group">
              <label>Stadt</label>
              <input type="text" id="city" placeholder="München" autocomplete="address-level2" />
            </div>
          </div>
          <div class="form-group">
            <label>Land</label>
            <select id="country" autocomplete="country">
              <option value="DE" selected>Deutschland</option>
              <option value="AT">Österreich</option>
              <option value="CH">Schweiz</option>
            </select>
          </div>
        </div>

        <div class="form-card">
          <h2>Zahlungsart</h2>
          <div class="payment-options">
            <label class="payment-option">
              <input type="radio" name="payment" value="credit" checked />
              <div>
                <div class="payment-option-label">Kreditkarte</div>
                <div class="payment-option-sub">Visa, Mastercard, American Express</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="payment" value="paypal" />
              <div>
                <div class="payment-option-label">PayPal</div>
                <div class="payment-option-sub">Sicher bezahlen über PayPal</div>
              </div>
            </label>
            <label class="payment-option">
              <input type="radio" name="payment" value="invoice" />
              <div>
                <div class="payment-option-label">Rechnung</div>
                <div class="payment-option-sub">Zahlung innerhalb von 14 Tagen</div>
              </div>
            </label>
          </div>
        </div>

        <div class="order-summary-card">
          <h3>Ihre Bestellung</h3>
          <div id="checkoutSummaryLines"></div>
        </div>

        <div style="display:flex; justify-content:flex-end; gap:12px;">
          <button class="btn-back" onclick="showCart()">Zurück</button>
          <button class="btn-primary" id="placeOrderBtn" onclick="placeOrder()">Bestellung aufgeben</button>
        </div>
      </div>

      <!-- Confirmation -->
      <div class="confirmation-view" id="confirmationView">
        <div class="confirmation-card">
          <div class="confirm-icon"></div>
          <h2>Vielen Dank!</h2>
          <p class="conf-sub">Ihre Bestellung wurde erfolgreich aufgegeben.</p>
          <p class="conf-sub" id="confEmail"></p>
          <p class="conf-order-nr" id="confOrderNr"></p>
          <div class="confirmation-actions">
            <a href="/" class="btn-primary">Zurück zur Startseite</a>
            <a href="/merch-shop" class="btn-ghost" style="display:inline-block; padding:10px 22px;">Weiter einkaufen</a>
          </div>
        </div>
      </div>

    </div>

    <script>
      function normalizeText(text) {
        if (!text) return text;
        return text
          .replaceAll("WeiÃŸ", "Weiß")
          .replaceAll("GrÃ¼n", "Grün")
          .replaceAll("MaÃŸ", "Maß")
          .replaceAll("OberflÃ¤che", "Oberfläche")
          .replaceAll("HÃ¼lle", "Hülle")
          .replaceAll("StoÃŸ", "Stoß")
          .replaceAll("MaÃŸstab", "Maßstab");
      }

      function normalizeImageUrl(url) {
        if (!url) return url;
        return url
          .replace("BMW_Merchandise_weiÃŸ.avif", "BMW_Merchandise_weiss.avif")
          .replace("BMW_Merchandise_weiß.avif", "BMW_Merchandise_weiss.avif");
      }

      async function loadCart() {
        const container = document.getElementById("cartContent");
        try {
          const res = await fetch("/api/cart");
          const { items, total } = await res.json();

          if (!items || !items.length) {
            container.innerHTML = `
              <div class="empty-state">
                <p>Ihr Warenkorb ist zurzeit noch leer.</p>
                <a href="/merch-shop" class="btn-primary">Jetzt entdecken</a>
              </div>`;
            return;
          }

          const list = items.map(item => `
            <div class="item" id="item-${item.id}">
              ${item.imageUrl
                ? `<img src="${normalizeImageUrl(item.imageUrl)}" alt="${normalizeText(item.name)}" />`
                : '<div style="width:120px;height:90px;background:#f1f5f9;border-radius:12px;flex-shrink:0"></div>'}
              <div class="item-info">
                <div class="item-meta">${item.type === "car" ? "Fahrzeug" : "Lifestyle & Merch"}</div>
                <div class="item-name">${normalizeText(item.name)}</div>
                ${item.details?.color ? `<div class="item-variant">Farbe: ${normalizeText(item.details.color)}</div>` : ""}
                <div class="qty-controls">
                  <button class="qty-btn" data-id="${item.id}" data-delta="-1">−</button>
                  <span class="qty-value">${item.quantity}</span>
                  <button class="qty-btn" data-id="${item.id}" data-delta="1">+</button>
                </div>
              </div>
              <div class="item-right">
                <div class="item-price">${(item.price * item.quantity).toLocaleString("de-DE", { style: "currency", currency: "EUR" })}</div>
                <button class="remove-btn" data-id="${item.id}">Entfernen</button>
              </div>
            </div>
          `).join("");

          container.innerHTML = list + `
            <div class="summary">
              <div>
                <div class="total-label">Gesamtsumme</div>
                <div style="font-size: 0.8rem; opacity: 0.5;">Inkl. MwSt. zzgl. Versand</div>
              </div>
              <div class="total-value">${total.toLocaleString("de-DE", { style: "currency", currency: "EUR" })}</div>
            </div>
            <div style="margin-top: 24px; text-align: right;">
              <button class="btn-primary" onclick="showCheckout()">Zur Kasse gehen</button>
            </div>`;

          container.querySelectorAll(".remove-btn").forEach(btn => {
            btn.addEventListener("click", async () => {
              btn.disabled = true;
              btn.textContent = "...";
              await fetch(`/api/cart/items/${btn.dataset.id}`, { method: "DELETE" });
              loadCart();
            });
          });

          container.querySelectorAll(".qty-btn").forEach(btn => {
            btn.addEventListener("click", async () => {
              btn.disabled = true;
              const qtyEl = btn.parentElement.querySelector(".qty-value");
              const newQty = parseInt(qtyEl.textContent) + parseInt(btn.dataset.delta);
              await fetch(`/api/cart/items/${btn.dataset.id}`, {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ quantity: newQty }),
              });
              loadCart();
            });
          });
        } catch (err) {
          container.innerHTML = '<div class="empty-state"><p>Fehler beim Laden des Warenkorbs.</p></div>';
        }
      }

      loadCart();

      document.getElementById("clearCartBtn").addEventListener("click", async () => {
        if (!confirm("Warenkorb wirklich leeren?")) return;
        await fetch("/api/cart", { method: "DELETE" });
        loadCart();
      });

      // ── Checkout flow ─────────────────────────────────────────────────

      let cartSnapshot = null;

      function showCart() {
        document.getElementById("cartWrapper").style.display = "";
        document.getElementById("checkoutView").classList.remove("active");
        document.getElementById("confirmationView").classList.remove("active");
        document.getElementById("step1").classList.add("active");
        document.getElementById("step2").classList.remove("active", "done");
        document.getElementById("step3").classList.remove("active", "done");
      }

      async function showCheckout() {
        try {
          const res = await fetch("/api/cart");
          const { items, total } = await res.json();
          if (!items || !items.length) return;
          cartSnapshot = { items, total };

          let linesHtml = items.map(item => `
            <div class="summary-line">
              <span class="summary-line-name">${normalizeText(item.name)}${item.quantity > 1 ? ` ×${item.quantity}` : ""}</span>
              <span class="summary-line-price">${(item.price * item.quantity).toLocaleString("de-DE", { style: "currency", currency: "EUR" })}</span>
            </div>`).join("");
          linesHtml += `
            <div class="summary-line">
              <span class="summary-line-name">Gesamtsumme</span>
              <span class="summary-line-price">${total.toLocaleString("de-DE", { style: "currency", currency: "EUR" })}</span>
            </div>`;
          document.getElementById("checkoutSummaryLines").innerHTML = linesHtml;

          document.getElementById("cartWrapper").style.display = "none";
          document.getElementById("checkoutView").classList.add("active");
          document.getElementById("step1").classList.add("active");
          document.getElementById("step2").classList.add("active");
          window.scrollTo({ top: 0, behavior: "smooth" });
        } catch {}
      }

      async function placeOrder() {
        const firstName = document.getElementById("firstName").value.trim();
        const lastName  = document.getElementById("lastName").value.trim();
        const email     = document.getElementById("emailField").value.trim();
        const street    = document.getElementById("street").value.trim();
        const zip       = document.getElementById("zip").value.trim();
        const city      = document.getElementById("city").value.trim();

        if (!firstName || !lastName || !email || !street || !zip || !city) {
          const inputs = ["firstName","lastName","emailField","street","zip","city"];
          inputs.forEach(id => {
            const el = document.getElementById(id);
            el.style.borderColor = el.value.trim() ? "" : "#ef4444";
          });
          return;
        }

        const btn = document.getElementById("placeOrderBtn");
        btn.disabled = true;
        btn.textContent = "Wird verarbeitet …";

        await fetch("/api/cart", { method: "DELETE" });

        const orderNr = "BMW-" + Date.now().toString(36).toUpperCase().slice(-6)
          + Math.random().toString(36).slice(2,5).toUpperCase();

        document.getElementById("confEmail").textContent =
          `Eine Bestätigung wird an ${email} gesendet.`;
        document.getElementById("confOrderNr").textContent =
          `Bestellnummer: ${orderNr}`;

        document.getElementById("step2").classList.add("done");
        document.getElementById("step3").classList.add("active", "done");
        document.getElementById("checkoutView").classList.remove("active");
        document.getElementById("confirmationView").classList.add("active");
        window.scrollTo({ top: 0, behavior: "smooth" });
      }
    </script>
  </body>
</html>
