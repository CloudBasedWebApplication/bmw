<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>Merch Shop</title>
    <style>
      body { font-family: sans-serif; margin: 2rem; background: #f4f4f4; }
      h1 { margin-bottom: 1.5rem; }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1.5rem;
      }
      .card {
        background: #fff;
        border-radius: 8px;
        padding: 1rem;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
      }
      .card h2 { font-size: 1rem; margin: 0 0 0.25rem; }
      .card .category { font-size: 0.8rem; color: #888; margin-bottom: 0.5rem; }
      .card .price { font-weight: bold; color: #1c69d4; margin-bottom: 0.5rem; }
      .card .detail { font-size: 0.85rem; color: #555; }
    </style>
  </head>
  <body>
    <h1>Merch Shop</h1>
    <div class="grid">
      <% products.forEach(function(p) { %>
        <div class="card">
          <h2><%= p.name %></h2>
          <div class="category"><%= p.category %><% if (p.color) { %> &middot; <%= p.color %><% } %></div>
          <div class="price"><%= parseFloat(p.price).toFixed(2) %> &euro;</div>
          <% if (p.description) { %>
            <div class="detail"><%= p.description %></div>
          <% } %>
          <% if (p.sizes) { %>
            <div class="detail" style="margin-top:0.4rem;">Gr&ouml;&szlig;en: <%= p.sizes %></div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </body>
</html>
