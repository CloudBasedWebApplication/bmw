<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Merch Shop</title>
    <style>
      :root { --accent: #0066b1; --bg: #f3f5f7; --panel: #fff; --muted: #5c6670; }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; background: var(--bg); }
      .topbar { padding: 18px 16px 0; }
      .topbar-inner { max-width: 1100px; margin: 0 auto; padding: 14px 18px; background: var(--panel); border-radius: 18px; box-shadow: 0 8px 24px rgba(0,0,0,.06); display: flex; align-items: center; justify-content: space-between; gap: 16px; }
      .brand { text-decoration: none; color: #111; font-weight: 700; letter-spacing: .03em; white-space: nowrap; }
      .nav-links { display: flex; flex-wrap: wrap; gap: 10px; }
      .nav-links a { text-decoration: none; color: var(--muted); padding: 8px 12px; border-radius: 999px; }
      .nav-links a.active, .nav-links a:hover { background: #eef4fb; color: var(--accent); }
      .layout { max-width: 1100px; margin: 0 auto; padding: 40px 20px; }
      h1 { font-size: 2rem; margin: 0 0 32px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; }
      .card { background: var(--panel); border-radius: 16px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,.07); display: flex; flex-direction: column; }
      .card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; background: #eee; }
      .card-body { padding: 16px; flex: 1; display: flex; flex-direction: column; }
      .card-body h2 { font-size: 1rem; margin: 0 0 4px; }
      .badge { display: inline-block; font-size: 0.75rem; background: #eef4fb; color: var(--accent); border-radius: 20px; padding: 2px 10px; margin-bottom: 8px; }
      .price { font-weight: 700; color: var(--accent); font-size: 1.1rem; margin-bottom: 6px; }
      .detail { font-size: 0.82rem; color: var(--muted); margin-bottom: 4px; }
      .add-btn { margin-top: auto; padding: 10px; border: none; border-radius: 8px; background: var(--accent); color: #fff; font-size: 0.9rem; cursor: pointer; font-weight: 600; }
      .add-btn:hover { background: #0055a0; }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">BMW Gateway</a>
        <nav class="nav-links" aria-label="Hauptnavigation">
          <a href="/">Home</a>
          <a href="/car-configurator">Configurator</a>
          <a href="/merch-shop" class="active">Merch Shop</a>
          <a href="/ai-feature">AI Feature</a>
          <a href="/road-to-supercar">Road To Supercar</a>
          <a href="/shopping-cart">Warenkorb</a>
        </nav>
      </div>
    </header>
    <div class="layout">
      <h1>Merch Shop</h1>
      <div class="grid">
        <% products.forEach(function(p) { %>
          <div class="card" id="product-<%= p.id %>">
            <img src="<%= p.imageUrl %>" alt="<%= p.name %>" loading="lazy" />
            <div class="card-body">
              <h2><%= p.name %></h2>
              <span class="badge"><%= p.category %><% if (p.color) { %> &middot; <%= p.color %><% } %></span>
              <div class="price"><%= parseFloat(p.price).toLocaleString("de-DE", { style: "currency", currency: "EUR" }) %></div>
              <% if (p.description) { %><div class="detail"><%= p.description %></div><% } %>
              <% if (p.sizes) { %><div class="detail">Größen: <%= p.sizes %></div><% } %>
              <button class="add-btn"
                data-id="<%= p.id %>"
                data-name="<%= p.name %> <%= p.color || '' %>"
                data-price="<%= p.price %>"
                data-image="<%= p.imageUrl %>">
                In den Warenkorb
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <script>
      document.querySelectorAll(".add-btn").forEach(btn => {
        btn.addEventListener("click", async () => {
          btn.disabled = true;
          await fetch("/api/cart/items", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              type: "merch",
              name: btn.dataset.name.trim(),
              price: parseFloat(btn.dataset.price),
              imageUrl: btn.dataset.image,
              quantity: 1,
              details: { productId: parseInt(btn.dataset.id) },
            }),
          });
          btn.textContent = "✓ Hinzugefügt";
          setTimeout(() => { btn.textContent = "In den Warenkorb"; btn.disabled = false; }, 2000);
        });
      });
    </script>
  </body>
</html>
